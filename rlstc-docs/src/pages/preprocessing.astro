---
import Layout from "../layouts/Layout.astro";
import CodeBlock from "../components/CodeBlock.astro";
import FlowStep from "../components/FlowStep.astro";
import DiagramCard from "../components/DiagramCard.astro";
---

<Layout title="Preprocessing | RLSTC Documentation" currentPage="/preprocessing">
  <div class="page-content py-12 lg:py-20">
    <div class="reveal">
      <span class="badge badge-purple mb-4">Data Pipeline</span>
      <h1 class="section-title text-3xl lg:text-4xl mb-3">Preprocessing Pipeline</h1>
      <p class="section-subtitle mb-12">
        Raw GPS trajectories from T-Drive (Beijing taxi dataset) undergo a 5-stage pipeline: 
        geographic filtering, length normalization, coordinate normalization, conversion to Traj objects, 
        and MDL-based simplification.
      </p>
    </div>

    <!-- Pipeline Image -->
    <DiagramCard caption="Four-stage preprocessing: Raw GPS → Bounding Box Filter → Z-Score Normalization → MDL Simplification" accent="purple">
      <img src="/images/preprocessing.png" alt="Preprocessing Pipeline Visualization" class="w-full rounded-lg" />
    </DiagramCard>

    <!-- Pipeline Steps -->
    <section class="mt-12">
      <FlowStep step={1} title="Geographic Filtering — processtrajs()" accent="purple">
        <p>Filters out GPS points outside Beijing's administrative boundary. Only points within the bounding box are kept:</p>
        <div class="glass p-4 mt-3 !rounded-lg">
          <table class="styled-table">
            <thead><tr><th>Dimension</th><th>Min</th><th>Max</th></tr></thead>
            <tbody>
              <tr><td>Longitude (x)</td><td class="font-mono text-purple">115.4°E</td><td class="font-mono text-purple">117.5°E</td></tr>
              <tr><td>Latitude (y)</td><td class="font-mono text-purple">39.4°N</td><td class="font-mono text-purple">41.6°N</td></tr>
            </tbody>
          </table>
        </div>
        <CodeBlock filename="preprocessing.py" title="Geographic Bounding Box Filter">
{`def processtrajs(trajs):
    trajslist = []
    for i in range(len(trajs)):
        temptraj = []
        for j in range(len(trajs[i])):
            # Keep only points inside Beijing's bounding box
            if (trajs[i][j][1] >= 39.4 and trajs[i][j][1] <= 41.6 and
                trajs[i][j][0] >= 115.4 and trajs[i][j][0] <= 117.5):
                temptraj.append(trajs[i][j])
        if len(temptraj) != 0:
            trajslist.append(temptraj)
    return trajslist`}
        </CodeBlock>
      </FlowStep>

      <FlowStep step={2} title="Length Normalization — processlength()" accent="teal">
        <p>Enforces trajectory length constraints. Trajectories longer than <code class="text-teal text-xs">max_length</code> (default: 500) are randomly downsampled while preserving order. Trajectories shorter than <code class="text-teal text-xs">min_length</code> (default: 10) are discarded.</p>
        <CodeBlock filename="preprocessing.py" title="Length Clamping with Random Downsampling">
{`def processlength(trajs, max_length, min_length):
    trajdata = []
    for i in range(len(trajs)):
        length = len(trajs[i])
        if length > max_length:
            # Random downsampling: select max_length random indices, keep sorted
            length_list = [i for i in range(length)]
            random_sample = random.sample(length_list, max_length)
            sorted_sample = sorted(random_sample)
            temp_traj = [trajs[i][idx] for idx in sorted_sample]
            trajdata.append(temp_traj)
        elif min_length <= length <= max_length:
            trajdata.append(trajs[i])
    return trajdata`}
        </CodeBlock>
      </FlowStep>

      <FlowStep step={3} title="Time Normalization — normtimetrajs()" accent="amber">
        <p>Applies Z-score normalization to timestamps across all trajectories. This centers timestamps around zero and scales them to unit variance, making temporal features comparable across different time periods.</p>
        <div class="math-block">
          <span class="text-text-primary font-mono">t_norm = (t - μ_t) / σ_t</span>
        </div>
        <CodeBlock filename="preprocessing.py" title="Z-Score Time Normalization">
{`def normtimetrajs(trajs):
    norm_trajs, ts = [], []
    for i in range(len(trajs)):
        for j in range(len(trajs[i])):
            ts.append(trajs[i][j][2])  # Collect all timestamps
    mean_t = np.mean(ts)
    std_t = np.std(ts)
    for i in range(len(trajs)):
        tmp_traj = []
        for j in range(len(trajs[i])):
            norm_t = (trajs[i][j][2] - mean_t) / std_t
            tmp_traj.append([trajs[i][j][0], trajs[i][j][1], norm_t])
        norm_trajs.append(np.array(tmp_traj))
    return norm_trajs`}
        </CodeBlock>
      </FlowStep>

      <FlowStep step={4} title="Object Conversion — convert2traj()" accent="purple">
        <p>Converts raw numpy arrays into <code class="text-teal text-xs">Traj</code> objects containing <code class="text-teal text-xs">Point</code> instances. This creates the object hierarchy used by all downstream modules.</p>
        <CodeBlock filename="preprocessing.py" title="Array → Object Conversion">
{`def convert2traj(trajdata):
    trajlists = []
    for i in range(len(trajdata)):
        traj_points = []
        for j in range(len(trajdata[i])):
            p = Point(trajdata[i][j][0], trajdata[i][j][1], trajdata[i][j][2])
            traj_points.append(p)
        ts, te = traj_points[0].t, traj_points[-1].t
        traj = Traj(traj_points, len(traj_points), ts, te, i)
        trajlists.append(traj)
    return trajlists`}
        </CodeBlock>
      </FlowStep>

      <FlowStep step={5} title="MDL Simplification — simplify()" accent="coral">
        <p>
          Uses the <strong>Minimum Description Length</strong> principle to remove redundant points from trajectories. 
          At each step, it compares the cost of simplification (replacing intermediate points with a direct segment) 
          against the cost of keeping the original points. If simplification is more expensive (i.e., too much information loss), a new anchor point is created.
        </p>
        <div class="glass p-4 mt-3 !rounded-lg">
          <h4 class="font-semibold text-xs text-accent mb-2">MDL Cost Components</h4>
          <ul class="text-text-muted text-sm space-y-1.5">
            <li><strong class="text-text-primary">Simplified cost:</strong> <code class="text-xs">0.5 × log₂(segment_length) + 0.5 × |Δt| + log₂(perpendicular_deviation)</code></li>
            <li><strong class="text-text-primary">Original cost:</strong> <code class="text-xs">Σ log₂(point_to_point_distance + |Δt|)</code></li>
            <li><strong class="text-text-primary">Decision:</strong> If simplified_cost &gt; original_cost → create anchor point</li>
          </ul>
        </div>
        <CodeBlock filename="preprocessing.py" title="MDL-Based Trajectory Simplification">
{`def simplify(points, traj_id):
    simp_points = [points[0]]  # Always keep first point
    start_index = 0
    length = 1
    while start_index + length < len(points):
        curr_index = start_index + length
        cost_simp = traj_mdl_comp(points, start_index, curr_index, 'simp')
        cost_origin = traj_mdl_comp(points, start_index, curr_index, 'orign')
        if cost_simp > cost_origin:
            # Simplification too costly → anchor this point
            simp_points.append(points[curr_index])
            start_index = curr_index
            length = 1
        else:
            length += 1  # Keep extending simplified segment
    if not simp_points[-1].equal(points[-1]):
        simp_points.append(points[-1])  # Always keep last point
    return Traj(simp_points, len(simp_points), ...)`}
        </CodeBlock>
      </FlowStep>
    </section>

    <!-- Full Pipeline -->
    <section class="mt-8 reveal">
      <h2 class="text-xl font-display font-bold text-text-primary mb-4">Complete Pipeline Execution</h2>
      <CodeBlock filename="preprocessing.py" title="__main__ — End-to-End Pipeline">
{`if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="preprocess")
    parser.add_argument("-trajfile", default='../data/Tdrive')
    parser.add_argument("-maxlen", type=int, default=500)
    parser.add_argument("-minlen", type=int, default=10)
    parser.add_argument("-simpledtrajfile", default='../data/Tdrive_norm_traj')
    args = parser.parse_args()

    trajs = pickle.load(open(args.trajfile, 'rb'))
    trajslist = processtrajs(trajs)         # Step 1: Geographic filter
    trajs = processlength(trajslist, 500, 10) # Step 2: Length normalization
    norm_trajs = normtimetrajs(trajs)         # Step 3: Z-score timestamps
    trajlists = convert2traj(norm_trajs)      # Step 4: Create Traj objects
    simpletrajs = getsimptrajs(trajlists)     # Step 5: MDL simplification
    pickle.dump(simpletrajs, open(args.simpledtrajfile, 'wb'), protocol=2)`}
      </CodeBlock>
    </section>

    <!-- Navigation -->
    <div class="flex justify-between items-center pt-8 mt-8 border-t border-white/[0.06] reveal">
      <a href="/data-structures" class="text-text-muted hover:text-text-primary text-sm transition-colors">← Data Structures</a>
      <a href="/distance-metrics" class="text-accent hover:text-accent-hover text-sm font-semibold transition-colors">Distance Metrics →</a>
    </div>
  </div>
</Layout>
